  color: #60a5fa;
}

.quick-action-button.calendar-action .quick-action-icon {
  color: #34d399;
}

.quick-action-button.target-action .quick-action-icon {
  color: #a78bfa;
}

.quick-action-button.lightbulb-action .quick-action-icon {
  color: #fbbf24;
}

.quick-action-title {
  font-size: 0.875rem;
  font-weight: 600;
  color: white;
  margin: 0;
  position: relative;
  z-index: 1;
}

.quick-action-subtitle {
  font-size: 0.75rem;
  color: #9ca3af;
  margin: 0.25rem 0 0 0;

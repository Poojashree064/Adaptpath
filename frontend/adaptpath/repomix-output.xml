/* How It Works Section */
.how-it-works-section {
  padding: 100px 0;
  background: linear-gradient(180deg, transparent 0%, rgba(168, 85, 247, 0.05) 50%, transparent 100%);
}

.steps-container {
  max-width: 900px;
  margin: 0 auto;
  position: relative;
}

.step-item {
  display: flex;
  gap: 40px;
  margin-bottom: 60px;
  position: relative;
  opacity: 0;
  animation: fadeInUp 0.8s ease forwards;
}

.step-item:nth-child(1) { animation-delay: 0.2s; }
.step-item:nth-child(3) { animation-delay: 0.4s; }
.step-item:nth-child(5) { animation-delay: 0.6s; }

.step-number {
  position: relative;
  width: 80px;
  height: 80px;
  flex-shrink: 0;
  background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%);
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  font-weight: 900;
  box-shadow: 0 20px 60px rgba(168, 85, 247, 0.4);
}

.step-glow {
  position: absolute;
  inset: -10px;
  background: inherit;
  border-radius: inherit;
  filter: blur(30px);
  opacity: 0.5;
  z-index: -1;
}

.step-content h3 {
  font-size: 28px;
  margin-bottom: 15px;
}

.step-content p {
  font-size: 16px;
  line-height: 1.7;
  color: rgba(255,255,255,0.7);
  margin-bottom: 20px;
}

.step-features {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.step-tag {
  padding: 6px 14px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  font-size: 13px;
  color: rgba(255,255,255,0.8);
}

.step-connector {
  width: 2px;
  height: 40px;
  background: linear-gradient(180deg, rgba(168, 85, 247, 0.5) 0%, transparent 100%);
  margin: -20px auto 0;
  position: relative;
  left: 40px;
}

.step-animation {
  position: absolute;
  right: -50px;
  top: 50%;
  transform: translateY(-50%);
  width: 200px;
  height: 200px;
  opacity: 0.3;
  pointer-events: none;
}

.step-anim-1 { animation: bounce 2s ease-in-out infinite; }
.step-anim-2 { animation: float 3s ease-in-out infinite; }
.step-anim-3 { animation: rotate 4s linear infinite; }

/* Testimonials Section */
.testimonials-section {
  padding: 100px 0;
}

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
}

.testimonial-card {
  padding: 35px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 24px;
  backdrop-filter: blur(10px);
  transition: all 0.3s;
  opacity: 0;
  animation: fadeInUp 0.8s ease forwards;
  animation-delay: var(--delay);
}

.testimonial-card:hover {

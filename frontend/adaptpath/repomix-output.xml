}

.resource-card-youtube:hover {
  background: rgba(255, 0, 0, 0.15);
}

.resource-card-website {
  background: rgba(59, 130, 246, 0.1);
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.resource-card-website:hover {
  background: rgba(59, 130, 246, 0.15);
}

.resource-icon {
  flex-shrink: 0;
}

.resource-info {
  flex: 1;
}

.resource-title {
  font-size: 14px;
  font-weight: 600;
  color: white;
  margin-bottom: 2px;
}

.resource-meta {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.6);
}

/* Action Buttons */
.action-buttons {
  display: flex;
  gap: 15px;

  margin-bottom: 15px;
}

.feature-desc {
  font-size: 15px;
  line-height: 1.6;
  color: rgba(255,255,255,0.7);
  margin-bottom: 20px;
}

.feature-stat {
  display: inline-block;
  padding: 8px 16px;
  background: rgba(168, 85, 247, 0.2);
  border: 1px solid rgba(168, 85, 247, 0.3);
  border-radius: 20px;

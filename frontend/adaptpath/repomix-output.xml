/* AITutor.css - Professional Dynamic Study Plan Theme */

.ai-tutor-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1625 0%, #2d1b3d 100%);
  padding: 2rem;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

.ai-tutor-wrapper {
  max-width: 1400px;
  margin: 0 auto;
}

/* Header Section */
.ai-tutor-header {
  background: rgba(30, 20, 40, 0.7);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 20px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  padding: 2rem;
  margin-bottom: 2rem;
  animation: slideDown 0.6s ease-out;
}

.ai-tutor-header-content {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.back-button {
  width: 44px;
  height: 44px;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s;
}

.back-button:hover {
  background: rgba(255, 255, 255, 0.15);
  transform: translateX(-3px);
}

.ai-tutor-icon-wrapper {
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  padding: 1.5rem;
  border-radius: 16px;
  box-shadow: 0 8px 20px rgba(139, 92, 246, 0.4);
}

.ai-tutor-icon {
  width: 2.5rem;
  height: 2.5rem;
  color: white;
}

.ai-tutor-title {
  font-size: 2rem;
  font-weight: 800;
  background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 0;
}

.ai-tutor-subtitle {
  color: #9ca3af;
  margin: 0.25rem 0 0 0;
}

.ai-tutor-status {
  display: flex;
  gap: 0.5rem;
  margin-left: auto;
}

.status-badge {
  padding: 0.5rem 1rem;
  border-radius: 9999px;
  font-size: 0.875rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(16, 185, 129, 0.1);
  border: 1px solid rgba(16, 185, 129, 0.3);
  color: #10b981;
}

.status-indicator {
  width: 8px;
  height: 8px;
  background: #10b981;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

/* Main Content Grid */
.ai-tutor-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 2rem;
}

@media (max-width: 1024px) {
  .ai-tutor-grid {
    grid-template-columns: 1fr;
  }
}

/* Chat Section */
.chat-container {
  background: rgba(30, 20, 40, 0.7);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 20px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  height: 700px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: fadeIn 0.6s ease-out 0.2s both;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.chat-messages::-webkit-scrollbar {
  width: 8px;
}

.chat-messages::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10px;
}

.chat-messages::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  border-radius: 10px;
}

.message-wrapper {
  display: flex;
  animation: messageSlideIn 0.3s ease-out;
}

.message-wrapper.user {
  justify-content: flex-end;
}

.message-wrapper.assistant {
  justify-content: flex-start;
}

.message-bubble {
  max-width: 80%;
  padding: 1rem 1.25rem;
  border-radius: 20px;
  word-wrap: break-word;
  white-space: pre-wrap;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  line-height: 1.6;
}

.message-bubble.user {
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  color: white;
  border-bottom-right-radius: 4px;
}

.message-bubble.assistant {
  background: rgba(30, 20, 40, 0.9);
  color: #e5e7eb;
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-bottom-left-radius: 4px;
}

.loading-indicator {
  display: flex;
  gap: 0.5rem;
  padding: 1rem;
}

.loading-dot {
  width: 8px;
  height: 8px;
  background: #8b5cf6;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
}

/* Chat Input */
.chat-input-container {
  border-top: 1px solid rgba(139, 92, 246, 0.2);
  padding: 1.5rem;
  background: rgba(17, 24, 39, 0.5);
}

.chat-input-wrapper {
  display: flex;
  gap: 0.75rem;
}

.chat-input {
  flex: 1;
  padding: 1rem 1.25rem;
  background: rgba(30, 20, 40, 0.9);
  border: 2px solid rgba(139, 92, 246, 0.2);
  border-radius: 16px;
  font-size: 1rem;
  color: white;
  transition: all 0.3s ease;
}

.chat-input::placeholder {
  color: #6b7280;
}

.chat-input:focus {
  outline: none;
  border-color: #8b5cf6;
  background: rgba(30, 20, 40, 1);
  box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
}

.chat-input:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.send-button {
  padding: 1rem 1.5rem;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  color: white;
  border: none;
  border-radius: 16px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(139, 92, 246, 0.4);
}

.send-button:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(139, 92, 246, 0.6);
}

.send-button:disabled {
  background: rgba(255, 255, 255, 0.1);
  cursor: not-allowed;
  box-shadow: none;
}

/* Sidebar */
.sidebar-container {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.sidebar-card {
  background: rgba(30, 20, 40, 0.7);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 20px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  padding: 1.5rem;
  animation: fadeIn 0.6s ease-out 0.4s both;
}

.sidebar-card-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: white;
  margin: 0 0 1rem 0;
}

/* Quick Actions */
.quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
}

.quick-action-button {
  padding: 1rem;
  background: rgba(30, 20, 40, 0.9);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 12px;
  text-align: left;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.quick-action-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.quick-action-button:hover::before {
  opacity: 0.15;
}

.quick-action-button:hover {
  transform: translateY(-2px);
  border-color: rgba(139, 92, 246, 0.5);
  box-shadow: 0 4px 15px rgba(139, 92, 246, 0.2);
}

.quick-action-icon {
  width: 1.25rem;
  height: 1.25rem;
  margin-bottom: 0.5rem;

export function generateStudyPlan(sectionAnalysis) {
  const plan = [];

  Object.entries(sectionAnalysis).forEach(([topic, data]) => {
    if (data.accuracy < 50) {
      plan.push({
        topic,
        priority: "HIGH",
        action: "Relearn + Practice"
      });
    } else if (data.accuracy < 70) {
      plan.push({
        topic,
        priority: "MEDIUM",
        action: "Revise"
      });
    }
  });

  return plan;
}
</file>

<file path="src/hooks/usePredict.jsx">
import { useState } from "react";
import { predict } from "../utils/api";

export default function usePredict() {
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);

  const runPrediction = async (input) => {
    try {
      setLoading(true);
      setError(null);
      const res = await predict(input);
      setResult(res);
    } catch (err) {
      setError(err.message || "Prediction failed");
    } finally {
      setLoading(false);
    }
  };

  return { result, loading, error, runPrediction };
}
</file>

